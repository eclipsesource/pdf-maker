{
  "name": "pdfmkr",
  "version": "0.6.1",
  "description": "Generate PDF documents from JavaScript objects",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/eclipsesource/pdf-maker.git"
  },
  "homepage": "https://github.com/eclipsesource/pdf-maker#readme",
  "keywords": [
    "pdf-maker",
    "pdf"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "import": "./dist/index.js",
    "module": "./dist/index.js"
  },
  "engines": {
    "node": ">=20",
    "npm": ">=10"
  },
  "scripts": {
    "build": "./scripts/build.sh",
    "lint": "eslint . --max-warnings=0 && prettier --check .",
    "test": "vitest run test",
    "verify": "npm run lint && npm run test && npm run examples && npm run build",
    "format": "prettier -w .",
    "fix": "eslint . --fix && prettier -w .",
    "examples": "./examples/run-all-examples.sh"
  },
  "dependencies": {
    "@ralfstx/pdf-core": "^0.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.0.16",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.0.16"
  }
}
